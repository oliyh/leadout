# Temporary / exploratory files
tmp/

# Monkey C build artifacts
datafield/leadout-datafield/bin/

# Garmin developer key — never commit; generate with VS Code → 'Monkey C: Generate Developer Key'
*.key
developer_key

# Node.js
node_modules/

# UI build output (generated by vite build / make ui-build)
server/public/
ui/dist/

# SQLite WAL journal files (ephemeral, alongside leadout.db)
server/leadout.db-shm
server/leadout.db-wal

# Lock files — committed but excluded from wildcards
!ui/package-lock.json
!server/package-lock.json

# Environment / secrets
.env
.env.*

# OS
.DS_Store
Thumbs.db
