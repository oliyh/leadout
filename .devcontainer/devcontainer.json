{
  "name": "Leadout",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "runArgs": [
    "--device=/dev/uinput",
    "--ipc=host"
  ],
  "mounts": [
    "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind,consistency=cached",
    "source=${localEnv:HOME}/dev/garmin-developer,target=/root/dev/garmin-developer,type=bind,consistency=cached"
  ],
  "containerEnv": {
    "DISPLAY": "${localEnv:DISPLAY}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "garmin.monkey-c",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "anthropic.claude-code"
      ],
      "settings": {
        "monkeyC.javaPath": "/usr/lib/jvm/java-21-openjdk-amd64",
        "monkeyC.developerKeyPath": "/root/dev/garmin-developer/developer_key"
      }
    }
  },
  "postCreateCommand": "npm install && cd server && npm install && cd ../ui && npm install"
}
